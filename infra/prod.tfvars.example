# Production environment variables
# Copy to prod.tfvars and fill in real values

aws_region  = "us-east-1"
environment = "production"
domain      = "hashguard.org"
image_tag   = "latest"

# Sensitive — pass via CLI or environment:
#   terraform apply -var="db_password=xxx" -var="stripe_secret_key=xxx" ...
# db_password       = ""
# stripe_secret_key = ""
# smtp_pass         = ""
# secret_key        = ""
