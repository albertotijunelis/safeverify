{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(hashguard_http_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(hashguard_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(hashguard_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Total Samples",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        { "expr": "hashguard_samples_total", "legendFormat": "Samples" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } }
      }
    },
    {
      "title": "Active Users (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        { "expr": "hashguard_active_users", "legendFormat": "Users" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }] } }
      }
    },
    {
      "title": "Analyses Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "increase(hashguard_analyses_total[24h])", "legendFormat": "Analyses" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "purple", "value": 0 }] } }
      }
    },
    {
      "title": "Ingest Jobs Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "hashguard_ingest_jobs_active", "legendFormat": "Jobs" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "orange", "value": 0 }, { "color": "red", "value": 5 }] } }
      }
    },
    {
      "title": "HTTP Status Codes",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (status) (increase(hashguard_http_requests_total[1h]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Analyses by Verdict",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "sum by (verdict) (increase(hashguard_analyses_total[24h]))",
          "legendFormat": "{{verdict}}"
        }
      ]
    },
    {
      "title": "Top Endpoints by Request Count",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr": "topk(10, sum by (endpoint) (increase(hashguard_http_requests_total[1h])))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(hashguard_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.1 }] }
        }
      }
    },
    {
      "title": "DB Query Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(hashguard_db_query_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["hashguard", "malware", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "HashGuard — API Dashboard",
  "uid": "hashguard-api"
}
