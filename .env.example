# HashGuard SaaS — Environment Configuration
# Copy to .env and fill in your values

# Database (PostgreSQL for SaaS, SQLite for local dev)
DATABASE_URL=sqlite:///hashguard.db
# DATABASE_URL=postgresql://hashguard:changeme@localhost:5432/hashguard

# Redis (for Celery task queue)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Authentication
HASHGUARD_AUTH=0
# Set to 1 to enable, 0 to disable

# API Keys
VT_API_KEY=
ABUSE_CH_API_KEY=

# Security
HASHGUARD_SECRET_KEY=
# Auto-generated if empty. Set for multi-instance deployments.

# Environment
HASHGUARD_ENV=development
# Options: development, production

# PostgreSQL (for docker-compose)
POSTGRES_PASSWORD=changeme

# ── Stripe Billing ─────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# Webhook secret (from: stripe listen --forward-to localhost:8000/api/billing/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email / SMTP (Resend) ──────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 100 emails/day
# Add & verify domain hashguard.org in Resend dashboard
# Create API key at https://resend.com/api-keys
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx
SMTP_FROM=noreply@hashguard.org

# ── Base URL (for verification links) ─────────────────────────────────────
HASHGUARD_URL=http://localhost:8000

# ── Custom Domain & SSL ───────────────────────────────────────────────────
# Your production domain (used by nginx + CORS)
DOMAIN=localhost
# Set to your domain for production: DOMAIN=hashguard.example.com
# Then obtain SSL cert:
#   docker compose run --rm certbot certonly --webroot -w /var/www/certbot -d hashguard.example.com

# ── OAuth2 Providers ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Dataset Hub Publishing ────────────────────────────────────────────────
HF_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=
